{
  "name": "calculadora-roi-medico-hospital-v6",
  "version": "6.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host localhost --port 5196 --strictPort",
    "dev:rede": "vite --host 0.0.0.0 --port 5196 --strictPort",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host localhost --port 4196 --strictPort",
    "wrangler:deploy": "npm run build && wrangler pages deploy dist",
    "d1:migrar:local": "wrangler d1 migrations apply hss_roi_db --local",
    "d1:migrar:remoto": "wrangler d1 migrations apply hss_roi_db --remote"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "22.19.17",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "4.7.0",
    "autoprefixer": "10.5.0",
    "postcss": "8.5.14",
    "tailwindcss": "3.4.19",
    "typescript": "5.9.3",
    "vite": "6.4.2"
  }
}
